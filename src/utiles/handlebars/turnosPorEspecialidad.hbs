<html lang="es">
<head>
<style>
    body {
        font-family: Arial, Helvetica, sans-serif;
        margin: 30px;
        color: #333;
    }

    .encabezado {
        text-align: center;
        margin-bottom: 30px;
    }

    .encabezado h1 {
        margin: 0;
    }

    .encabezado p {
        margin: 5px 0;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 8px;
    }

    th {
        background-color: #f2f2f2;
        text-align: center;
    }

    .texto-centro {
        text-align: center;
    }

    .texto-derecha {
        text-align: right;
    }
</style>
</head>
<body>
    <div class="encabezado">
        <h1>Informe de Turnos por Especialidad</h1>
        <p>Sistema de Gestión de Turnos Médicos</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Especialidad</th>
                <th>Cantidad de Turnos</th>
                <th>Facturación Total</th>
            </tr>
        </thead>
        <tbody>
            {{#each especialidades}}
            <tr>
                <td>{{especialidad}}</td>
                <td class="texto-centro">{{cantidad_turnos}}</td>
                <td class="texto-derecha">$ {{facturacion_total}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</body>
</html>